# Database Configuration
# Default PostgreSQL container url:
DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/repo_analyzer
# Fallback to SQLite if PostgreSQL is not available:
# DATABASE_URL=sqlite:///./repo_analyzer.db

# LLM Configuration (Groq)
GROQ_API_KEY=your_groq_api_key_here

# Embedding Configuration
# Options: 'local' (sentence-transformers), 'gemini' (google-generativeai), 'openai'
EMBEDDING_PROVIDER=local

# Optional API Keys for embeddings if not using 'local'
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Server Port
PORT=8000
HOST=0.0.0.0
